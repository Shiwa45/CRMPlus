# .env.example  — copy to .env and fill in values
# Never commit .env to git

SECRET_KEY=your-very-secret-django-key-change-this-before-production

DEBUG=True

# ── PostgreSQL (required for django-tenants) ──────────────────────────────────
DB_NAME=crm_pro
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# ── Optional overrides ────────────────────────────────────────────────────────
# ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
# TIME_ZONE=Asia/Kolkata

# ── Celery (required for periodic IndiaMART lead polling) ─────────────────────
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Meta (Facebook) Lead Ads ─────────────────────────────────────────────────
# META_APP_SECRET=your-meta-app-secret-for-webhook-signature-validation
#
# IndiaMART and Meta API keys are stored per-tenant in the Integration model.
# Configure them via API:  POST /api/integrations/
#   service: "indiamart"  |  api_key: "<your IndiaMART CRM key>"
#   service: "meta_leads" |  api_key: "<page access token>"
#                            extra: '{"page_id":"...","verify_token":"...","app_secret":"..."}'
